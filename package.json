{
  "name": "autocore-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/ensure-puppeteer-browser.mjs",
    "dev": "next dev",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "prebuild": "python3 scripts/generate-favicon-ico.py && node scripts/build-documents-css.mjs",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:import && npm run test:import-motors",
    "migrate:rbac": "tsx scripts/migrate-rbac.ts",
    "migrate:billing": "tsx scripts/backfill-billing-subscriptions.ts",
    "deploy:billing-functions": "bash scripts/deploy-billing-functions.sh",
    "setup:stripe-secret": "bash scripts/setup-stripe-firebase-secret.sh",
    "assets:sync-from-native": "bash scripts/sync-brand-assets-from-native.sh",
    "assets:generate-favicon": "python3 scripts/generate-favicon-ico.py",
    "test:import": "node --import tsx --test src/lib/accounting/labels.test.ts src/lib/warehouse/import/preprocessor.test.ts src/lib/warehouse/import/validation.test.ts src/lib/warehouse/import/format-presets.test.ts src/lib/warehouse/import/firestore-sanitize.test.ts src/lib/warehouse/import/sku-resolver.test.ts src/lib/company/upload-company-logo-utils.test.ts src/lib/grid/grid-column-autocomplete.test.ts",
    "build:documents-css": "node scripts/build-documents-css.mjs",
    "generate:document-templates": "node scripts/generate-document-templates.mjs",
    "install:browser": "npx puppeteer browsers install chrome",
    "test:import-motors": "node --import tsx --test src/lib/import/import-engine.test.ts src/lib/import/ingestion.test.ts src/lib/domain/domain-dictionary.test.ts src/domain/inventory-taxonomy.test.ts src/lib/navigation/sidebar-edit-model.test.ts src/lib/warehouse/inventory-subcategory-index.test.ts src/lib/motors/import/sheet-mapper.test.ts src/lib/motors/import/ai-mapper.test.ts src/lib/motors/import/excel-import-engine-rows.test.ts src/lib/motors/import/sheet-recovery.test.ts src/lib/motors/import/specific-category-intelligence.test.ts src/lib/motors/import/brand-engine-intelligence.test.ts src/lib/motors/import/import-row-integrity.test.ts src/lib/navigation/business-navigation.test.ts src/lib/navigation/inventory-collections.test.ts src/lib/navigation/pinned-filters.test.ts",
    "tauri:sync-url": "node scripts/sync-tauri-app-url.mjs",
    "tauri": "tauri",
    "tauri:dev": "node scripts/sync-tauri-app-url.mjs && tauri dev",
    "tauri:build": "node scripts/sync-tauri-app-url.mjs && tauri build",
    "tauri:build:mac": "node scripts/sync-tauri-app-url.mjs && tauri build --target aarch64-apple-darwin",
    "tauri:build:mac-intel": "node scripts/sync-tauri-app-url.mjs && tauri build --target x86_64-apple-darwin",
    "tauri:build:win": "node scripts/sync-tauri-app-url.mjs && tauri build --target x86_64-pc-windows-msvc",
    "tauri:publish-downloads": "node scripts/copy-tauri-downloads.mjs"
  },
  "dependencies": {
    "@barba/core": "^2.10.3",
    "@base-ui/react": "^1.5.0",
    "@gsap/react": "^2.1.2",
    "@sparticuz/chromium": "^149.0.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.97",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-virtual": "^3.13.26",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "animejs": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^2.0.1",
    "date-fns": "^4.3.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.5.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "puppeteer-core": "^25.1.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tauri-plugin-siwa-api": "^1.0.0",
    "tw-animate-css": "^1.4.0",
    "web-vitals": "^5.3.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
