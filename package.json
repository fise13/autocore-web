{
  "name": "autocore-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "python3 scripts/generate-favicon-ico.py && node scripts/build-documents-css.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "migrate:rbac": "tsx scripts/migrate-rbac.ts",
    "migrate:billing": "tsx scripts/backfill-billing-subscriptions.ts",
    "deploy:billing-functions": "bash scripts/deploy-billing-functions.sh",
    "assets:sync-from-native": "bash scripts/sync-brand-assets-from-native.sh",
    "assets:generate-favicon": "python3 scripts/generate-favicon-ico.py",
    "test:import": "node --import tsx --test src/lib/warehouse/import/preprocessor.test.ts src/lib/warehouse/import/validation.test.ts src/lib/warehouse/import/format-presets.test.ts src/lib/warehouse/import/firestore-sanitize.test.ts src/lib/warehouse/import/sku-resolver.test.ts src/lib/company/upload-company-logo-utils.test.ts src/lib/grid/grid-column-autocomplete.test.ts",
    "build:documents-css": "node scripts/build-documents-css.mjs",
    "generate:document-templates": "node scripts/generate-document-templates.mjs",
    "install:browser": "npx puppeteer browsers install chrome",
    "test:import-motors": "node --import tsx --test src/lib/motors/import/sheet-mapper.test.ts src/lib/motors/import/ai-mapper.test.ts"
  },
  "dependencies": {
    "@barba/core": "^2.10.3",
