NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_APPLE_WEB_CLIENT_ID=com.wise.autocore.web
# apple_js (default) | firebase_handler
NEXT_PUBLIC_APPLE_AUTH_MODE=apple_js
# Apple JS: redirect by default. Popup only if NEXT_PUBLIC_APPLE_JS_USE_POPUP=true
# NEXT_PUBLIC_APPLE_JS_USE_POPUP=true
# Apple JS redirect Return URL (optional override). Default: <current-origin>/login
# Must match Apple Developer → Services ID → Return URLs exactly.
# NEXT_PUBLIC_APPLE_JS_REDIRECT_URI=https://your-app.vercel.app/login

# App URL for Stripe Checkout return links (web). On Vercel set to production domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Apple JS local dev — Apple Developer rejects "localhost" in Domains. Use hosts alias:
#   sudo sh -c 'echo "127.0.0.1 local.autocore.dev" >> /etc/hosts'
#   NEXT_PUBLIC_APP_URL=http://local.autocore.dev:3000
# Apple Developer: Domain local.autocore.dev, Return URL http://local.autocore.dev:3000/login
# Or deploy to Vercel and register https://your-app.vercel.app/login
# Production split: NEXT_PUBLIC_APP_URL=https://app.autocore.example
# NEXT_PUBLIC_MARKETING_URL=https://autocore.example
# Single Vercel preview (app + marketing on one host): set BOTH URLs to the same
# *.vercel.app domain — avoids /login redirect loops. Landing: /marketing, app: /login
# NEXT_PUBLIC_APP_URL=https://autocore-web.vercel.app
# NEXT_PUBLIC_MARKETING_URL=https://autocore-web.vercel.app
#
# Full Vercel env checklist: see .env.vercel.example

# --- Vercel server-only (paste in dashboard, not committed) ---
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_STORAGE_BUCKET=autocore-6066c.firebasestorage.app

# Optional: custom Spline 3D scene for marketing hero (scene.splinecode URL from spline.design)
# NEXT_PUBLIC_SPLINE_HERO_SCENE=https://prod.spline.design/your-scene/scene.splinecode

# Stripe Price IDs (test mode — from Product catalog export)
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_1TbiZUHo5bmy0A9LC86I6wJJ
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_1TbiarHo5bmy0A9LD3SafymR
NEXT_PUBLIC_STRIPE_PRICE_FREE=price_1TbiblHo5bmy0A9Lc8CwYfit

# Demo account — one-click «Попробовать демо» from marketing
# With FIREBASE_SERVICE_ACCOUNT_PATH (or JSON on Vercel) the account is created automatically on first visit.
# Optional password fallback when Admin SDK is unavailable:
DEMO_ACCOUNT_EMAIL=demo@autocore.app
# DEMO_ACCOUNT_PASSWORD=your-secure-demo-password

# Server-only (Firebase Functions — do NOT prefix with NEXT_PUBLIC_):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# APP_URL=https://your-app.vercel.app
# STRIPE_PRICE_PRO_MONTHLY=price_1TbiZUHo5bmy0A9LC86I6wJJ
# STRIPE_PRICE_PRO_YEARLY=price_1TbiarHo5bmy0A9LD3SafymR
