# Tauri desktop shell — loads the Vercel web app in a native window.
# Default: https://autocore-web.vercel.app/login

# Override only for local testing:
# DESKTOP_APP_URL=https://autocore-web.vercel.app

# Download links on the marketing site (after npm run tauri:publish-downloads):
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_MAC=https://autocore-web.vercel.app/downloads/AutoCore-mac.dmg
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_WIN=https://autocore-web.vercel.app/downloads/AutoCore-windows.exe
