# Copy these into Vercel → Project → Settings → Environment Variables
# Production + Preview unless noted otherwise.

# --- Firebase (client) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server) — required for PDF / warranty generation ---
# Paste the FULL minified service account JSON (one line). Do NOT use "..." placeholders.
# Download: Firebase Console → Project settings → Service accounts → Generate new private key.
# If this is missing or invalid, motor sales still work but PDF documents will fail.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"autocore-6066c",...}
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_STORAGE_BUCKET=autocore-6066c.firebasestorage.app

# --- App URLs (production split) ---
# IMPORTANT: include the https:// scheme. A bare host (app.myautocore.com)
# breaks login links → https://myautocore.com/app.myautocore.com/login.
NEXT_PUBLIC_MARKETING_URL=https://myautocore.com
NEXT_PUBLIC_APP_URL=https://app.myautocore.com

# --- SEO: search console verification (optional) ---
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_YANDEX_VERIFICATION=

# --- Apple Sign-In (apple_js mode) ---
# MUST be the Services ID (e.g. com.wise.autocore.web), NOT the App ID / bundle (com.wise.AutoCore.app).
NEXT_PUBLIC_APPLE_WEB_CLIENT_ID=com.wise.autocore.web
NEXT_PUBLIC_APPLE_AUTH_MODE=apple_js
# Optional override; default is <current-origin>/login at runtime
# NEXT_PUBLIC_APPLE_JS_REDIRECT_URI=https://autocore-web.vercel.app/login

# Apple Developer (manual, not env):
#   Domain: myautocore.com (marketing), app.myautocore.com (app)
#   Return URLs (both required):
#     https://app.myautocore.com/login
#     https://app.myautocore.com/api/auth/apple-redirect
# Firebase → Auth → Authorized domains: app.myautocore.com, myautocore.com

# --- Stripe (public price IDs) ---
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_FREE=

# --- Demo (optional) ---
DEMO_ACCOUNT_EMAIL=demo@autocore.app
# DEMO_ACCOUNT_PASSWORD=

# --- Desktop (Tauri shell → Vercel) ---
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_MAC=https://myautocore.com/downloads/AutoCore-mac.dmg
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_WIN=https://myautocore.com/downloads/AutoCore-windows.exe
# NEXT_PUBLIC_DESKTOP_DOWNLOADS_BASE_URL=https://myautocore.com

# --- Public contacts (marketing footer, /contact, SEO) ---
NEXT_PUBLIC_AUTOCORE_SUPPORT_PHONE=+77471795869
NEXT_PUBLIC_AUTOCORE_SUPPORT_EMAIL=support@myautocore.com

# --- Resend (email invites) ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=AutoCore <support@myautocore.com>

# --- Documents / PDF ---
# On Vercel, Puppeteer uses the deployment URL automatically when NEXT_PUBLIC_APP_URL is unset.
# Optional: dedicated HMAC secret for /render/documents tokens (recommended in production).
# DOCUMENT_RENDER_SECRET=
